<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <TextView
        android:id="@+id/distanceText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Distância: -- km"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#66000000"
        android:padding="8dp">

        <TextView
            android:id="@+id/raioLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Raio: 2 km"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekBarRaio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="6"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnNavegacao"
        android:layout_width="124dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="8dp"
        android:text="Modo Navegação" />

    <Button
        android:id="@+id/btnCancelarRota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cancelar rota"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"/>

</FrameLayout>